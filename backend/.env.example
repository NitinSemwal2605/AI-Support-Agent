# Database Configuration
# Use the direct connection string for syncing / migrations (e.g., from Neon)
DATABASE_URL="postgresql://user:password@host/neondb?sslmode=require"

# Pooler URL for potential future connection pooling
DATABASE_URL_POOLER="postgresql://user:password@pooler-host/neondb?sslmode=require"

# AI Configuration
GROQ_API_KEY="your-groq-api-key"

# Server Configuration
PORT=3001
NODE_ENV="development"
FRONTEND_URL="http://localhost:5173"
